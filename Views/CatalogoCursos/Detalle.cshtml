@model Practica2.ViewModels.CursoDetalleViewModel

@{
    ViewData["Title"] = "Detalle de curso";
}

<h1 class="mb-3">@Model.Curso.Nombre</h1>

@if (TempData["ExitoInscripcion"] is string exito)
{
    <div class="alert alert-success">@exito</div>
}

@if (TempData["ErrorInscripcion"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Codigo</dt>
            <dd class="col-sm-9">@Model.Curso.Codigo</dd>

            <dt class="col-sm-3">Creditos</dt>
            <dd class="col-sm-9">@Model.Curso.Creditos</dd>

            <dt class="col-sm-3">Horario</dt>
            <dd class="col-sm-9">@Model.Curso.HorarioInicio.ToString("HH:mm") - @Model.Curso.HorarioFin.ToString("HH:mm")</dd>

            <dt class="col-sm-3">Cupos disponibles</dt>
            <dd class="col-sm-9">@Model.CuposDisponibles</dd>
        </dl>
    </div>
</div>

<div class="mt-4 d-flex gap-2">
    @if (User.Identity?.IsAuthenticated == true)
    {
        @if (Model.YaInscrito)
        {
            <button class="btn btn-secondary" disabled>Ya inscrito</button>
        }
        else if (Model.CuposDisponibles <= 0)
        {
            <button class="btn btn-secondary" disabled>Sin cupos</button>
        }
        else
        {
            <form asp-action="Inscribirse" method="post">
                <input type="hidden" name="id" value="@Model.Curso.Id" />
                <button type="submit" class="btn btn-success">Inscribirse</button>
            </form>
        }
    }
    else
    {
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">Inicia sesion para inscribirte</a>
    }

    <a asp-action="Index" class="btn btn-outline-secondary">Volver al catalogo</a>
</div>
